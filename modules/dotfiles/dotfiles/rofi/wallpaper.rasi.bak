* {
    bg:             #1a1b26;
    fg:             #283457;
    secondary:      #bb9af7;
    outline:        #353D57;
    text-color:     #a9b1d6;
    text-color-alt: rgba (169, 177, 214, 50%);
    black-color:    #000;

    selected:       rgba (158, 206, 106, 100%);
    selected-border:#9ece6a;

    urgent:         #ff6b81;

    border-radius: 22px;
    font: "JetBrainsMono Nerd Font 13";
}

configuration {
    show-icons: true;
    display-drun: "Apps";
    kb-row-up: "Alt+k";
    kb-row-down: "Alt+j";
    kb-row-left: "Alt+h";
    kb-row-right: "Alt+l";
}

window {
    transparency: "real";
    location: center;
    anchor: center;

    width: 50%;
    height: 39%;

    background-color: @bg;

    border: 2px;
    border-color: rgba (255,255,255,20%);

    border-radius: @border-radius;

    padding: 16px;
}

mainbox {
    background-color: @fg;
    spacing: 20px;
    children: [ inputbar, listview ];
}

inputbar {
    background-color: @fg;

    border-radius: 0;

    padding: 10px 12px 0px 12px;

    children: [ prompt, entry ];
}

prompt {
    text-color: @text-color;
    background-color: #16161e;
    border-color:@secondary;
    padding: 2px 9px 2px 6px;
    border: 2px;
}

entry {
    border: 2px;
    background-color: #16161e;
    border-color:@secondary;
    text-color: @text-color;
    placeholder: "Search wallpapers...";
    placeholder-color: @text-color-alt;
    padding: 4px 6px 4px 16px;
}

listview {
    background-color: @fg;
    columns: 5;
    lines: 1;

    spacing: 6px;
    cycle: true;
    dynamic: true;
    scrollbar: false;

    layout: vertical;
}

element {
    orientation: vertical;
    // border-radius: 20px;
    padding: 10px;
    spacing: 12px;
    background-color: transparent;
}

element normal.normal {
    background-color: transparent;
}

element selected.normal {
    background-color: @selected;

    border: 2px;
    border-color: @selected-border;
}

element-icon {
    size: 240px;
    background-color: transparent;
    border-radius: 16px;
    horizontal-align: 0.5;
    vertical-align: 0.5;
}

// element-text {
//     text-color: @fg;
//     horizontal-align: 0.5;
//     vertical-align: 0.5;
//     margin: 6px 0px 0px 0px;
// }

mode-switcher {
    enabled: false;
}
